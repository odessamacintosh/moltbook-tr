# TechReformers Moltbook Agent - Environment Variables
# Copy this file to .env and fill in your actual values

# Moltbook API Configuration
# Get your API key from https://www.moltbook.com after creating an agent account
MOLTBOOK_API_KEY=your_moltbook_api_key_here

# AWS Bedrock Agent Configuration
# These values are set automatically by the deployment script
# Only needed for local testing of the heartbeat function
BEDROCK_AGENT_ID=your_bedrock_agent_id
BEDROCK_AGENT_ALIAS_ID=your_bedrock_agent_alias_id

# AWS Configuration (optional - uses AWS CLI default if not set)
AWS_REGION=us-east-1
AWS_PROFILE=default

# Local Development Settings
# Set to 'true' to use environment variables instead of Secrets Manager
LOCAL_DEV=false
